# Copy to .env (gitignored) and fill in. Used by python-dotenv on startup.

# Required everywhere
DJANGO_SETTINGS_MODULE=config.settings.development

# Production-only (Render injects DATABASE_URL automatically when bound)
SECRET_KEY=replace-with-a-long-random-string-50-chars-minimum
DATABASE_URL=postgresql://user:pass@host:5432/dbname
ALLOWED_HOSTS=ens-network-api.onrender.com
CORS_ALLOWED_ORIGINS=https://ens-network.vercel.app
CSRF_TRUSTED_ORIGINS=https://ens-network.vercel.app
